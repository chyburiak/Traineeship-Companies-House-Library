##################################
### UiPath Generated Folders
##################################

# .local/
# - Stores machine-specific runtime data created by UiPath Studio
# - Varies per developer/machine and should never be source-controlled
/.local/

# .objects/
# - Contains compiled workflow objects and intermediate build artifacts
# - Fully regenerated by UiPath and not part of the source of truth
/.objects/

# .settings/
# - Holds local Studio and execution settings
# - Environment-specific and not portable between machines
/.settings/

# .tmh/
# - UiPath Test Manager / execution history metadata
# - Generated at runtime and safe to regenerate
/.tmh/

# Exception_Screenshots
# Runtime folder created by UiPath to store screenshots captured during exceptions.
# Contents are environment-specific and regenerated on each run.
# Safe to ignore.
 /Exception_Screenshots/

##################################
### OS / System Files
##################################

# Desktop.ini
# - Windows Explorer metadata file
Desktop.ini

# .DS_Store
# - macOS Finder metadata file (may appear even on non-macOS dev machines)
**/.DS_Store

# ~*
# - Temporary/backup files created by editors
~*

##################################
### Visual Studio Code
##################################

# .vscode/
# - Ignore local editor configuration by default
# - Explicitly allow shared workspace settings below
.vscode/*

# VS Code project configuration files that are safe to commit
# The `!` at the start negates the ignore rule, ensuring these files are tracked
# even if the parent .vscode/ folder is ignored. These files contain shared
# project-specific settings and tooling info, but no sensitive personal data.
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# .history/
# - Local file history generated by VS Code extensions
.history/

# *.vsix
# - Packaged VS Code extensions
*.vsix

##################################
### JetBrains IDEs (Optional)
##################################
# .idea/
# - JetBrains IDE project metadata (PhpStorm, Rider, IntelliJ, etc.)
.idea/

# *.iml, *.ipr, *.iws
# - Module and project files generated by JetBrains IDEs
*.iml
*.ipr
*.iws

# out/
# - Default JetBrains compiler output directory
out/

# cmake-build-*/
# - CMake build directories (used by some JetBrains IDEs)
cmake-build-*/

# Test Result files.
Data/